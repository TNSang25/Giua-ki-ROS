<?xml version="1.0"?>
<launch>
    <arg name="urdf_model" default="$(find-pkg-share my_robot_description)/urdf/Final.urdf.xacro"/>
    <arg name="rviz_config" default="$(find-pkg-share my_robot_description)/rviz/config.rviz"/>
    <arg name="world_file" default="$(find-pkg-share gazebo_map)/worlds/test_world.sdf"/>
    <arg name="gazebo_config_path" default="$(find-pkg-share robot_bringup)/config/gazebo_bridge.yaml"/>
    <arg name="robot_name" default="my_robot"/>
    <arg name="slam_params_file" default="$(find-pkg-share robot_bringup)/config/my_slam_params.yaml"/>

    <set_parameter name="use_sim_time" value="true" />

    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="-r $(var world_file)"/>
    </include>

    <node pkg="robot_state_publisher" exec="robot_state_publisher" output="screen">
        <param name="robot_description" type="str" value="$(command 'xacro $(var urdf_model)')"/>
    </node>

    <node pkg="ros_gz_bridge" exec="parameter_bridge">
        <param name="config_file" value="$(var gazebo_config_path)" />
    </node>

    <node pkg="joint_state_publisher" exec="joint_state_publisher" name="joint_state_publisher" output="screen" />

    <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen" args="-d $(var rviz_config)"/>

    <node pkg="ros_gz_sim" exec="create" args="-name $(var robot_name) -topic robot_description -x 0.0 -y 0.0 -z 0.5" output="screen"/>

    <node pkg="slam_toolbox" exec="async_slam_toolbox_node" name="slam_toolbox" output="screen">
        <param from="$(var slam_params_file)" />
    </node>
</launch>